      "tags": [
        "Final Posting"
      ],
      "summary": "Archive Current Postings",
      "description": "Archive all records from the current Posting table to the FinalPosting table.\nThis copies all data but does not delete from the original table.",
      "operationId": "archive_current_postings_api_final_posting_archive_post",
