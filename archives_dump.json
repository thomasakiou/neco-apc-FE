        "200": {
          "description": "Successful Response",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FinalPostingBulkUploadResponse"
              }
            }
          }
        }
      },
      "security": [
        {
          "HTTPBearer": []
        }
      ]
    }
  },
